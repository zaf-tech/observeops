# ObserveOps — copy to .env and fill in the platforms you have
# Keys are NEVER logged or persisted beyond in-memory usage.

# ── LLM API Keys (provider is selected in the UI, not here) ──────────
# Ollama — runs locally, no key needed. Just set model + URL if non-default.
OLLAMA_MODEL=llama3.2
OLLAMA_BASE_URL=http://host.docker.internal:11434

# Anthropic — needed only if you pick "Claude Sonnet" in the UI
ANTHROPIC_API_KEY=
CLAUDE_MODEL_ID=claude-sonnet-4-6

# Google — needed only if you pick "Gemini Flash-Lite" in the UI
GOOGLE_API_KEY=
GEMINI_MODEL=gemini-2.0-flash-lite

# DeepSeek — needed only if you pick "DeepSeek V3" in the UI
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat

# ── AWS ──────────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1

# ── Azure ─────────────────────────────────────────────────────────────
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_SUBSCRIPTION_ID=

# ── GCP ───────────────────────────────────────────────────────────────
GOOGLE_APPLICATION_CREDENTIALS=
GCP_PROJECT_ID=

# ── GitHub ────────────────────────────────────────────────────────────
GITHUB_TOKEN=
GITHUB_ORG=

# ── GitLab ────────────────────────────────────────────────────────────
GITLAB_TOKEN=
GITLAB_URL=https://gitlab.com
GITLAB_GROUP=

# ── Bitbucket ─────────────────────────────────────────────────────────
BITBUCKET_USERNAME=
BITBUCKET_APP_PASSWORD=
BITBUCKET_WORKSPACE=

# ── Jenkins ───────────────────────────────────────────────────────────
JENKINS_URL=
JENKINS_USER=
JENKINS_TOKEN=

# ── Azure DevOps ──────────────────────────────────────────────────────
AZURE_DEVOPS_TOKEN=
AZURE_DEVOPS_ORG=

# ── CircleCI ──────────────────────────────────────────────────────────
CIRCLECI_TOKEN=

# ── ArgoCD ────────────────────────────────────────────────────────────
ARGOCD_URL=
ARGOCD_TOKEN=

# ── SonarQube / SonarCloud ────────────────────────────────────────────
SONAR_TOKEN=
SONAR_URL=https://sonarcloud.io
SONAR_ORG=

# ── Snyk ──────────────────────────────────────────────────────────────
SNYK_TOKEN=
SNYK_ORG=

# ── Artifactory ───────────────────────────────────────────────────────
ARTIFACTORY_URL=
ARTIFACTORY_TOKEN=

# ── Nexus ─────────────────────────────────────────────────────────────
NEXUS_URL=
NEXUS_USER=
NEXUS_PASSWORD=
